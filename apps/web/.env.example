# =============================================================================
# Copy this file to .env.local and fill in real values (never commit .env.local)
#   cp apps/web/.env.example apps/web/.env.local
# =============================================================================

# --- Clerk (required for sign-in; create app at https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Local development only: bypass Clerk when CAPTCHA/bot protection blocks keyless auth.
NEXT_PUBLIC_AUTH_BYPASS=false
# Optional local development only: use an existing Clerk user/org tenant key.
# NEXT_PUBLIC_AUTH_BYPASS_USER_ID=user_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/home
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/home

# --- App URL (optional; used for OAuth redirects — match your dev port) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Python backend (required for live API data) ---
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- LLM (Content Agent) ---
# LLM runs on the API service via OPENAI_API_KEY in services/api/.env

# --- Supabase (optional; for direct client reads in future) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- DC notes ingest BFF → FastAPI (required for sheet persistence) ---
INTERNAL_API_URL=http://localhost:8000
INTERNAL_API_SECRET=change_me_to_a_long_random_string

# --- Knowledge base UI (match KB_SHARED_MODE on API) ---
NEXT_PUBLIC_KB_SHARED=true

# --- Google Calendar integration (optional; Settings → Integrations) ---
# GOOGLE_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# GOOGLE_WEBHOOK_SECRET=generate_a_long_random_string
