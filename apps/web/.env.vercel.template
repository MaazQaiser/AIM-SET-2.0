# =============================================================================
# Copy each line into Vercel → Project → Settings → Environment Variables
# Apply to: Production, Preview, and Development (as needed)
# =============================================================================

# --- Required for build + sign-in (from https://dashboard.clerk.com → API Keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Set automatically in vercel.json (no action needed) ---
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
# NEXT_PUBLIC_KB_SHARED=true

# --- Your public FastAPI host (NOT the Vercel URL) ---
# Production: deploy API per docs/API_DEPLOYMENT.md (Railway/Render + Dockerfile.api)
# Dev-only tunnel: docs/PATH_A_ACTIVE.md — do NOT use loca.lt URLs in Production
API_URL=https://your-api-host.example.com
INTERNAL_API_URL=https://your-api-host.example.com
INTERNAL_API_SECRET=
NEXT_PUBLIC_API_URL=https://your-api-host.example.com
NEXT_PUBLIC_WS_URL=wss://your-api-host.example.com

# --- App URL (Clerk domains + redirects) ---
NEXT_PUBLIC_APP_URL=https://aim-set-2-0-web.vercel.app

# --- Live call demo on production UI (optional) ---
NEXT_PUBLIC_ENABLE_DEMO_TRANSCRIPT=true
# Also on API host services/api/.env: DEMO_TRANSCRIPT_REPLAY=true

# Supabase keys live on the API host only (SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY).
# Vercel does not need NEXT_PUBLIC_SUPABASE_* for this app.
