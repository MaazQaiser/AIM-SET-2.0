# Required — DC notes and KB vector search use Supabase Postgres + pgvector
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Database password (Settings → Database) — used only by scripts/apply_supabase_migrations.py
# SUPABASE_DB_PASSWORD=your-database-password

# Apply migrations in infra/supabase/migrations/ (001, 002, 003) via Supabase SQL editor or CLI

# Shared secret — must match INTERNAL_API_SECRET in apps/web/.env.local
INTERNAL_SECRET=change_me_to_a_long_random_string

# Embeddings for KB uploads and DC note ingest (offline deterministic fallback if unset)
OPENAI_API_KEY=sk-...
KB_STORAGE_BUCKET=kb-assets
KB_MAX_UPLOAD_BYTES=52428800
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_WORKER_POLL_INTERVAL_MS=2000
KB_INGEST_SYNC=false

# Shared team KB: all users see the same library (not internet-public)
KB_SHARED_MODE=true
KB_SHARED_TENANT_KEY=dc-copilot-shared

# Content Studio (Anthropic Claude for generation + template vision)
ANTHROPIC_API_KEY=sk-ant-...
CONTENT_TEMPLATES_BUCKET=content-templates
CONTENT_EXPORTS_BUCKET=content-exports
CONTENT_STUDIO_SYNC_INGEST=true

# Live call — Recall.ai transcript webhooks (register URL in Recall dashboard)
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=
# Optional: POST /api/v1/webhooks/recall/demo-segment?call_id=... when true
DEMO_TRANSCRIPT_REPLAY=false
